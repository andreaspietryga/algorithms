Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{
   RowBox[{
   "The", " ", "figure", " ", "illustrates", " ", "the", " ", "sequence", " ",
     "of", " ", "prices", " ", "chosen", " ", "by", " ", "Player", " ", "1", " ",
     "over", " ", 
    RowBox[{"time", ".", "Given"}], " ", "that", " ", "an", " ", 
    "equilibrium", " ", "is", " ", "defined", " ", "as", " ", "a", " ", "set",
     " ", "of", " ", "price", " ", "choices", " ", "from", " ", "which", " ", 
    "neither", " ", "player", " ", "deviates", " ", "for", " ", "a", " ", 
    "minimum", " ", "of", " ", "100", " ", "episodes"}], ",", 
   RowBox[{
   "the", " ", "graph", " ", "displays", " ", "only", " ", "those", " ", 
    "price", " ", "selections", " ", "observed", " ", "up", " ", "to", " ", 
    "the", " ", "point", " ", "at", " ", "which", " ", "this", " ", 
    "condition", " ", "is", " ", 
    RowBox[{"satisfied", ".", " ", "In"}], " ", "that", " ", "specific", " ", 
    "case", " ", "never"}], ",", " ", 
   RowBox[{
   "thats", " ", "why", " ", "we", " ", "see", " ", "observations", " ", "up",
     " ", "until", " ", "episode", " ", "50000"}]}], "*)"}]], "Input",
 CellChangeTimes->{{3.9839594907528267`*^9, 
  3.983959521686632*^9}},ExpressionUUID->"c92245f2-5422-fc49-97ed-\
af2118cfd26d"],

