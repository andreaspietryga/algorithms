    "equilibrium", " ", "is", " ", "defined", " ", "as", " ", "a", " ", "set",
     " ", "of", " ", "price", " ", "choices", " ", "from", " ", "which", " ", 
    "neither", " ", "player", " ", "deviates", " ", "for", " ", "a", " ", 
    "minimum", " ", "of", " ", "100", " ", "episodes"}], ",", 
   RowBox[{
   "the", " ", "graph", " ", "displays", " ", "only", " ", "those", " ", 
    "price", " ", "selections", " ", "observed", " ", "up", " ", "to", " ", 
    "the", " ", "point", " ", "at", " ", "which", " ", "this", " ", 
    "condition", " ", "is", " ", 
    RowBox[{"satisfied", ".", " ", "In"}], " ", "that", " ", "specific", " ", 
    "case", " ", "never"}], ",", " ", 
   RowBox[{
   "thats", " ", "why", " ", "we", " ", "see", " ", "observations", " ", "up",
     " ", "until", " ", "episode", " ", "60000"}]}], "*)"}]], "Input",
